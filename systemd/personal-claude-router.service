[Unit]
Description=Personal Claude Router — subscription-only per-prompt model routing
After=network-online.target
Wants=network-online.target

[Service]
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/personal-claude-router/router
Environment=UPSTREAM=https://api.anthropic.com
ExecStart=/home/YOUR_USER/personal-claude-router/.venv/bin/uvicorn app:app --host 0.0.0.0 --port 4000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
